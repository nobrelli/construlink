{
	"expo": {
		"name": "Construlink",
		"slug": "construlink",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./src/assets/images/icon.png",
		"scheme": "construlink",
		"userInterfaceStyle": "automatic",
		"splash": {
			"image": "./src/assets/images/splash.png",
			"resizeMode": "contain",
			"backgroundColor": "#141314"
		},
		"ios": {
			"supportsTablet": true
		},
		"android": {
			"adaptiveIcon": {
				"foregroundImage": "./src/assets/images/adaptive-icon.png",
				"backgroundColor": "#141314"
			},
			"package": "com.nobrelli.construlink"
		},
		"web": {
			"bundler": "metro",
			"output": "static",
			"favicon": "./src/assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			"expo-font",
			[
				"expo-build-properties",
				{
					"android": {
						"newArchEnabled": true
					},
					"ios": {
						"newArchEnabled": true
					}
				}
			],
			"expo-secure-store"
		],
		"experiments": {
			"typedRoutes": true
		}
	}
}
