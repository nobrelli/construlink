{
	"name": "@construlink/api",
	"license": "MIT",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"start:dev": "nest start --watch --type-check",
		"start:debug": "nest start --debug --watch --type-check",
		"start:watch": "tsx watch ./src/index.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:apply": "drizzle-kit push",
		"db:seed": "tsx --env-file=.env ./src/database/seeder.ts"
	},
	"devDependencies": {
		"@faker-js/faker": "^9.2.0",
		"@nestjs/testing": "^10.4.9",
		"@swc/cli": "^0.5.1",
		"@swc/core": "^1.9.3",
		"@types/jest": "^29.5.14",
		"@types/node": "^22.9.0",
		"@types/pg": "^8.11.10",
		"drizzle-kit": "^0.28.1",
		"tsx": "^4.19.2",
		"typescript": "^5.6.3"
	},
	"dependencies": {
		"@nestjs/common": "^10.4.9",
		"@nestjs/core": "^10.4.9",
		"@nestjs/platform-fastify": "^10.4.9",
		"@sinclair/typebox": "^0.34.8",
		"dotenv": "^16.4.5",
		"drizzle-orm": "^0.36.3",
		"fastify": "^5.1.0",
		"fastify-plugin": "^5.0.1",
		"pg": "^8.13.1",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1"
	},
	"packageManager": "yarn@4.5.1"
}
