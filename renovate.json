{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:base"],
	"packageRules": [
		{
			"matchPackageNames": [
				"react",
				"react-dom",
				"react-native*",
				"@react-native*/*",
				"@react-native-community/*",
				"@react-navigation*/*",
				"expo*",
				"@expo/*",
				"typescript",
				"jest*",
				"@types/jest",
				"@types/react",
				"@babel*/*",
				"@testing-library/react-native"
			],
			"enabled": false
		}
	],
	"prHourlyLimit": 1
}
