{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended"],
	"packageRules": [
		{
			"matchPackageNames": [
				"react",
				"react-dom",
				"react-native**",
				"@react-native**",
				"expo**",
				"@expo**",
				"typescript",
				"jest**",
				"@types/jest",
				"@types/react",
				"@babel**",
				"@testing-library/react-native"
			],
			"enabled": false
		}
	]
}
